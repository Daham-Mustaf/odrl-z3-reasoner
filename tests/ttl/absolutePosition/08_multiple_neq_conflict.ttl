@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix ex: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt: <http://qudt.org/vocab/unit/> .


# Test 08: Multiple neq eliminating isAnyOf CONFLICT
# Expected: CONFLICT
# isAnyOf [0, 30, 60] AND ≠0 AND ≠30 AND ≠60 = ∅

ex:policy01 a odrl:Set ;
    odrl:uid ex:policy01 ;
    odrl:permission [
        a odrl:Permission ;
        odrl:action odrl:play ;
        odrl:target ex:video01 ;
        odrl:constraint [
            a odrl:LogicalConstraint ;
            odrl:and (
                [
                    a odrl:Constraint ;
                    odrl:leftOperand odrl:absolutePosition ;
                    odrl:operator odrl:isAnyOf ;
                    odrl:rightOperand ( "0"^^xsd:decimal "30"^^xsd:decimal "60"^^xsd:decimal ) ;
                    odrl:unit qudt:SEC
                ]
                [
                    a odrl:Constraint ;
                    odrl:leftOperand odrl:absolutePosition ;
                    odrl:operator odrl:neq ;
                    odrl:rightOperand "0"^^xsd:decimal ;
                    odrl:unit qudt:SEC
                ]
                [
                    a odrl:Constraint ;
                    odrl:leftOperand odrl:absolutePosition ;
                    odrl:operator odrl:neq ;
                    odrl:rightOperand "30"^^xsd:decimal ;
                    odrl:unit qudt:SEC
                ]
                [
                    a odrl:Constraint ;
                    odrl:leftOperand odrl:absolutePosition ;
                    odrl:operator odrl:neq ;
                    odrl:rightOperand "60"^^xsd:decimal ;
                    odrl:unit qudt:SEC
                ]
            )
        ]
    ] .
