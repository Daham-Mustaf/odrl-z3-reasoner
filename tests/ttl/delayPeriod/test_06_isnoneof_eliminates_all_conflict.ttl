@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix ex:   <http://example.org/> .
@prefix dct:  <http://purl.org/dc/terms/> .

# =============================================================================
# TEST 06: isNoneOf Eliminates All Options Conflict
# =============================================================================
# Description: delayPeriod is NOT any of {30D, 60D} AND must be one of {30D, 60D}
# Scenario: "Exclude standard embargos but require standard embargos"
# Expected: CONFLICT
# Reason: Cannot be in set AND not in same set
# Analysis:
#   α(isNoneOf {2592000, 5184000}) = [0, +∞) \ {2592000, 5184000}
#   α(isAnyOf {2592000, 5184000}) = {2592000, 5184000}
#   Meet: ∅
# =============================================================================

ex:policy_delay_period_06
    a odrl:Set ;
    dct:description "isNoneOf eliminates all: must be in {30D, 60D} AND not in {30D, 60D}"@en ;
    odrl:uid ex:policy_delay_period_06 ;
    odrl:permission [
        a odrl:Permission ;
        odrl:action odrl:distribute ;
        odrl:target ex:asset_06 ;
        odrl:constraint ex:constraint_06_composite
    ] .

ex:constraint_06_composite
    a odrl:Constraint ;
    odrl:and (ex:constraint_06a ex:constraint_06b) .

ex:constraint_06a
    a odrl:Constraint ;
    odrl:leftOperand odrl:delayPeriod ;
    odrl:operator odrl:isNoneOf ;
    odrl:rightOperand ("P30D"^^xsd:duration "P60D"^^xsd:duration) .

ex:constraint_06b
    a odrl:Constraint ;
    odrl:leftOperand odrl:delayPeriod ;
    odrl:operator odrl:isAnyOf ;
    odrl:rightOperand ("P30D"^^xsd:duration "P60D"^^xsd:duration) .
