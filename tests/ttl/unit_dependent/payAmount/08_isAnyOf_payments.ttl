@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt: <http://qudt.org/vocab/unit/> .
@prefix ex: <http://example.org/> .

# TEST: isAnyOf with range constraint
# c1: payAmount isAnyOf [10, 25, 50, 100] EUR
# c2: payAmount gteq 75 EUR
# Expected: POSSIBLY-COMPATIBLE (100 satisfies both)

ex:policy a odrl:Set ;
    odrl:uid ex:policy ;
    odrl:permission ex:perm1 .

ex:perm1 a odrl:Permission ;
    odrl:action odrl:compensate ;
    odrl:constraint ex:c1, ex:c2 .

ex:c1 a odrl:Constraint ;
    odrl:uid ex:c1 ;
    odrl:leftOperand odrl:payAmount ;
    odrl:operator odrl:isAnyOf ;
    odrl:rightOperand ("10.00"^^xsd:decimal "25.00"^^xsd:decimal "50.00"^^xsd:decimal "100.00"^^xsd:decimal) ;
    odrl:unit qudt:EUR .

ex:c2 a odrl:Constraint ;
    odrl:uid ex:c2 ;
    odrl:leftOperand odrl:payAmount ;
    odrl:operator odrl:gteq ;
    odrl:rightOperand "75.00"^^xsd:decimal ;
    odrl:unit qudt:EUR .