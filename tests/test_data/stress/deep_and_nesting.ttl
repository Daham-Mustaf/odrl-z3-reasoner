@prefix odrl: <http://www.w3.org/ns/odrl/2/\> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema\#\> .
@prefix ex: <http://example.org/\> .

ex:policy a odrl:Policy ;
    odrl:permission [
        odrl:action odrl:use ;
        odrl:constraint ex:and_outer
    ] .

ex:and_outer a odrl:LogicalConstraint ;
    odrl:and ex:c1, ex:and_inner .

ex:and_inner a odrl:LogicalConstraint ;
    odrl:and ex:c2, ex:c3 .

ex:c1 a odrl:Constraint ;
    odrl:leftOperand odrl:count ;
    odrl:operator odrl:lteq ;
    odrl:rightOperand "10"^^xsd:integer .

ex:c2 a odrl:Constraint ;
    odrl:leftOperand odrl:percentage ;
    odrl:operator odrl:lteq ;
    odrl:rightOperand "50"^^xsd:decimal .

ex:c3 a odrl:Constraint ;
    odrl:leftOperand odrl:elapsedTime ;
    odrl:operator odrl:lteq ;
    odrl:rightOperand "3600"^^xsd:integer .
