  </rdf:Description>
  <rdf:Description rdf:about="http://w3id.org/odrl/bcp47/zh-Hans">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:notation rdf:datatype="http://www.w3.org/2001/XMLSchema#language">zh-Hans</skos:notation>
    <skos:prefLabel xml:lang="en">Chinese (Simplified)</skos:prefLabel>
    <skos:inScheme rdf:resource="http://w3id.org/odrl/bcp47/scheme"/>
    <skos:broader rdf:resource="http://w3id.org/odrl/bcp47/zh"/>
    <dct:language rdf:resource="https://www.omg.org/spec/LCC/Languages/ISO639-1-LanguageCodes/Chinese"/>
    <dct:conformsTo rdf:resource="https://www.omg.org/spec/LCC/Languages/ISO15924-CodeSet/Hans"/>
    <dct:source rdf:resource="https://www.rfc-editor.org/rfc/rfc5646#section-2.2.3"/>
    <rdfs:comment xml:lang="en">Chinese (Simplified) is a script variant of ZH. Per BCP47 (RFC 5646, Section 2.2.3), script subtags (ISO 15924) specialize a language by writing system. The 'Hans' script (Simplified Han script) distinguishes this variant from other writing systems of the same language.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://w3id.org/odrl/bcp47/sr">
