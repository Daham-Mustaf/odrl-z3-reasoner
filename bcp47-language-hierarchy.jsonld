  {
    "@id": "http://w3id.org/odrl/bcp47",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology"
    ],
    "http://purl.org/dc/terms/created": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-01-21"
      }
    ],
    "http://purl.org/dc/terms/creator": [
      {
        "@value": "Your Name"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@language": "en",
        "@value": "\nThis ontology provides semantic grounding for ODRL language constraints (odrl:language) \nby mapping BCP47 language tags to SKOS concepts with hierarchical relationships.\n\nDESIGN PRINCIPLES:\n1. Zero new vocabulary: Reuses only existing W3C and OMG standards\n2. Standards-based: All mappings grounded in official specifications\n3. Hierarchical: Regional and script variants linked via skos:broader\n4. Component-linked: Tags decomposed and linked to LCC authoritative URIs\n5. SPARQL-queryable: Enables semantic reasoning over language hierarchies\n\nSTANDARDS REUSED:\n- SKOS (W3C): Taxonomy structure (skos:Concept, skos:broader, skos:notation)\n- OWL (W3C): Identity relations (owl:sameAs)\n- Dublin Core: Metadata and component links (dct:language, dct:spatial, dct:conformsTo)\n- LCC (OMG): Authoritative URIs for languages (ISO 639), regions (ISO 3166), scripts (ISO 15924)\n    "
      }
    ],
    "http://purl.org/dc/terms/source": [
      {
        "@id": "https://www.rfc-editor.org/rfc/rfc5646"
      },
      {
        "@id": "https://www.omg.org/spec/LCC/"
      },
      {
        "@id": "https://www.iso.org/standard/4766.html"
      },
      {
        "@id": "https://www.iso.org/standard/63545.html"
      }
    ],
    "http://purl.org/dc/terms/title": [
      {
        "@language": "en",
        "@value": "BCP47 Language Tag Hierarchy for ODRL Policy Reasoning"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "No custom properties or classes defined. Uses only standard vocabularies: SKOS, OWL, Dublin Core, LCC."
      }
    ],
    "http://www.w3.org/2002/07/owl#versionInfo": [
      {
        "@value": "1.0"
      }
    ]
  },
