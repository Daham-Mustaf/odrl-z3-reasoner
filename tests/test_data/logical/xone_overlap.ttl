@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ex: <http://example.org/> .

# XONE with overlapping branches - count <= 10 and count >= 5 overlap
ex:policy a odrl:Policy ;
    odrl:permission [
        odrl:action odrl:use ;
        odrl:constraint ex:xone_constraint
    ] .

ex:xone_constraint a odrl:LogicalConstraint ;
    odrl:xone ex:c1, ex:c2 .

ex:c1 a odrl:Constraint ;
    odrl:leftOperand odrl:count ;
    odrl:operator odrl:lteq ;
    odrl:rightOperand "10"^^xsd:integer .

ex:c2 a odrl:Constraint ;
    odrl:leftOperand odrl:count ;
    odrl:operator odrl:gteq ;
    odrl:rightOperand "5"^^xsd:integer .
