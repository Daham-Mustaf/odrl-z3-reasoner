@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix ex:   <http://example.org/> .


# EXPECTED: CONFLICT

ex:policy a odrl:Set ;
  odrl:permission [
    odrl:action odrl:use ;
    odrl:constraint [
      odrl:or (
        [ odrl:leftOperand odrl:percentage ; odrl:operator odrl:lt ; odrl:rightOperand "0" ]
        [ odrl:leftOperand odrl:percentage ; odrl:operator odrl:gt ; odrl:rightOperand "100" ]
      )
    ]
  ] .
