@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix ex: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt: <http://qudt.org/vocab/unit/> .

# Test 01: Pixel range CONFLICT
# Expected: CONFLICT
# (≥100 AND ≤500) AND (≥1000 AND ≤2000) = [100,500] ∩ [1000,2000] = ∅
# Thumbnail vs full-size conflict

ex:policy01 a odrl:Set ;
    odrl:uid ex:policy01 ;
    odrl:permission [
        a odrl:Permission ;
        odrl:action odrl:display ;
        odrl:target ex:image01 ;
        odrl:constraint [
            a odrl:LogicalConstraint ;
            odrl:and (
                [
                    a odrl:LogicalConstraint ;
                    odrl:and (
                        [
                            a odrl:Constraint ;
                            odrl:leftOperand odrl:absoluteSize ;
                            odrl:operator odrl:gteq ;
                            odrl:rightOperand "100"^^xsd:decimal ;
                            odrl:unit qudt:PX
                        ]
                        [
                            a odrl:Constraint ;
                            odrl:leftOperand odrl:absoluteSize ;
                            odrl:operator odrl:lteq ;
                            odrl:rightOperand "500"^^xsd:decimal ;
                            odrl:unit qudt:PX
                        ]
                    )
                ]
                [
                    a odrl:LogicalConstraint ;
                    odrl:and (
                        [
                            a odrl:Constraint ;
                            odrl:leftOperand odrl:absoluteSize ;
                            odrl:operator odrl:gteq ;
                            odrl:rightOperand "1000"^^xsd:decimal ;
                            odrl:unit qudt:PX
                        ]
                        [
                            a odrl:Constraint ;
                            odrl:leftOperand odrl:absoluteSize ;
                            odrl:operator odrl:lteq ;
                            odrl:rightOperand "2000"^^xsd:decimal ;
                            odrl:unit qudt:PX
                        ]
                    )
                ]
            )
        ]
    ] .