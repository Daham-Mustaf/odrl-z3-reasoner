@prefix dpv: <https://w3id.org/dpv#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# W3C Data Privacy Vocabulary (DPV) - Purpose Taxonomy
# Source: https://w3c.github.io/dpv/2.2/dpv/ (Section 4: Purposes)
# This file contains the purpose hierarchy for ODRL constraint grounding
# =============================================================================

# -----------------------------------------------------------------------------
# Ontology Metadata
# -----------------------------------------------------------------------------
<https://w3id.org/dpv/purposes> a skos:ConceptScheme ;
    dct:title "DPV Purpose Taxonomy"@en ;
    dct:description "W3C Data Privacy Vocabulary purpose taxonomy for grounding ODRL odrl:purpose constraints."@en ;
    dct:source <https://w3c.github.io/dpv/2.2/dpv/> ;
    dct:license <https://www.w3.org/copyright/document-license/> ;
    skos:note "DPV uses skos:broader/narrower for hierarchies. All purpose concepts are instances of dpv:Purpose."@en .

# -----------------------------------------------------------------------------
# Top-Level Purpose Concept
# -----------------------------------------------------------------------------
dpv:Purpose a skos:Concept ;
    rdfs:label "Purpose"@en ;
    skos:definition "A defined purpose for exercising an action or processing data."@en ;
    skos:topConceptOf <https://w3id.org/dpv/purposes> .

# =============================================================================
# LEVEL 1: Primary Purpose Categories
# =============================================================================

dpv:AcademicResearch a skos:Concept, dpv:Purpose ;
    rdfs:label "Academic Research"@en ;
    skos:definition "Purposes associated with conducting academic research."@en ;
    skos:broader dpv:ResearchAndDevelopment ;
    skos:inScheme <https://w3id.org/dpv/purposes> .

dpv:Advertising a skos:Concept, dpv:Purpose ;
    rdfs:label "Advertising"@en ;
    skos:definition "Purposes associated with conducting advertising activities."@en ;
    skos:broader dpv:Marketing ;
    skos:inScheme <https://w3id.org/dpv/purposes> .

dpv:CommercialPurpose a skos:Concept, dpv:Purpose ;
