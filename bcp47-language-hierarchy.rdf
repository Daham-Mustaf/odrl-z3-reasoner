  <rdf:Description rdf:about="http://w3id.org/odrl/bcp47/de">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:notation rdf:datatype="http://www.w3.org/2001/XMLSchema#language">de</skos:notation>
