
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix ex: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt: <http://qudt.org/vocab/unit/> .

# Test 12: resolution isNoneOf COMPATIBLE
# Expected: CONSISTENT (isNoneOf [72, 150] AND =300 = {300})

ex:policy01 a odrl:Set ;
    odrl:uid ex:policy01 ;
    odrl:permission [
        a odrl:Permission ;
        odrl:action odrl:print ;
        odrl:target ex:asset01 ;
        odrl:constraint [
            a odrl:LogicalConstraint ;
            odrl:and (
                [
                    a odrl:Constraint ;
                    odrl:leftOperand odrl:resolution ;
                    odrl:operator odrl:isNoneOf ;
                    odrl:rightOperand ( "72"^^xsd:decimal "150"^^xsd:decimal ) ;
                    odrl:unit qudt:DPI
                ]
                [
                    a odrl:Constraint ;
                    odrl:leftOperand odrl:resolution ;
                    odrl:operator odrl:eq ;
                    odrl:rightOperand "300"^^xsd:decimal ;
                    odrl:unit qudt:DPI
                ]
            )
        ]
    ] .