@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix ex: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Test 01: Temporal range CONFLICT
# Expected: CONFLICT
# (≥0 AND ≤100) AND (≥200 AND ≤300) = [0,100] ∩ [200,300] = ∅
# First segment vs later segment conflict

ex:policy01 a odrl:Set ;
    odrl:uid ex:policy01 ;
    odrl:permission [
        a odrl:Permission ;
        odrl:action odrl:play ;
        odrl:target ex:video01 ;
        odrl:constraint [
            a odrl:LogicalConstraint ;
            odrl:and (
                [
                    a odrl:LogicalConstraint ;
                    odrl:and (
                        [
                            a odrl:Constraint ;
                            odrl:leftOperand odrl:absoluteTemporalPosition ;
                            odrl:operator odrl:gteq ;
                            odrl:rightOperand "0"^^xsd:decimal
                        ]
                        [
                            a odrl:Constraint ;
                            odrl:leftOperand odrl:absoluteTemporalPosition ;
                            odrl:operator odrl:lteq ;
                            odrl:rightOperand "100"^^xsd:decimal
                        ]
                    )
                ]
                [
                    a odrl:LogicalConstraint ;
                    odrl:and (
                        [
                            a odrl:Constraint ;
                            odrl:leftOperand odrl:absoluteTemporalPosition ;
                            odrl:operator odrl:gteq ;
                            odrl:rightOperand "200"^^xsd:decimal
                        ]
                        [
                            a odrl:Constraint ;
                            odrl:leftOperand odrl:absoluteTemporalPosition ;
                            odrl:operator odrl:lteq ;
                            odrl:rightOperand "300"^^xsd:decimal
                        ]
                    )
                ]
            )
        ]
    ] .
