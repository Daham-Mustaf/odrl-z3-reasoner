@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix ex: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt: <http://qudt.org/vocab/unit/> .

# Test 04: isNoneOf eliminates valid option CONFLICT
# Expected: CONFLICT
# isNoneOf [50, 100, 150] AND =100 = ∅

ex:policy01 a odrl:Set ;
    odrl:uid ex:policy01 ;
    odrl:permission [
        a odrl:Permission ;
        odrl:action odrl:use ;
        odrl:target ex:asset01 ;
        odrl:constraint [
            a odrl:LogicalConstraint ;
            odrl:and (
                [
                    a odrl:Constraint ;
                    odrl:leftOperand odrl:payAmount ;
                    odrl:operator odrl:isNoneOf ;
                    odrl:rightOperand ( "50"^^xsd:decimal "100"^^xsd:decimal "150"^^xsd:decimal ) ;
                    odrl:unit qudt:EUR
                ]
                [
                    a odrl:Constraint ;
                    odrl:leftOperand odrl:payAmount ;
                    odrl:operator odrl:eq ;
                    odrl:rightOperand "100"^^xsd:decimal ;
                    odrl:unit qudt:EUR
                ]
            )
        ]
    ] .
