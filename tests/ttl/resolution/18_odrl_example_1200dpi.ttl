@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix ex: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt: <http://qudt.org/vocab/unit/> .

# Test 18: ODRL example - 1200 DPI high quality print
# Expected: CONSISTENT (single valid constraint)

ex:policy01 a odrl:Set ;
    odrl:uid ex:policy01 ;
    odrl:permission [
        a odrl:Permission ;
        odrl:action odrl:print ;
        odrl:target ex:image01 ;
        odrl:constraint [
            a odrl:Constraint ;
            odrl:leftOperand odrl:resolution ;
            odrl:operator odrl:lteq ;
            odrl:rightOperand "1200"^^xsd:decimal ;
            odrl:unit qudt:DPI
        ]
    ] .
