@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix ex: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Test 16: OR one valid branch CONSISTENT
# Expected: CONSISTENT
# (≤60 OR ≥300) AND ≥600 = [600,∞) via second branch

ex:policy01 a odrl:Set ;
    odrl:uid ex:policy01 ;
    odrl:permission [
        a odrl:Permission ;
        odrl:action odrl:play ;
        odrl:target ex:video01 ;
        odrl:constraint [
            a odrl:LogicalConstraint ;
            odrl:and (
                [
                    a odrl:LogicalConstraint ;
                    odrl:or (
                        [
                            a odrl:Constraint ;
                            odrl:leftOperand odrl:absoluteTemporalPosition ;
                            odrl:operator odrl:lteq ;
                            odrl:rightOperand "60"^^xsd:decimal
                        ]
                        [
                            a odrl:Constraint ;
                            odrl:leftOperand odrl:absoluteTemporalPosition ;
                            odrl:operator odrl:gteq ;
                            odrl:rightOperand "300"^^xsd:decimal
                        ]
                    )
                ]
                [
                    a odrl:Constraint ;
                    odrl:leftOperand odrl:absoluteTemporalPosition ;
                    odrl:operator odrl:gteq ;
                    odrl:rightOperand "600"^^xsd:decimal
                ]
            )
        ]
    ] .
