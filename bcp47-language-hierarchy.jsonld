  {
    "@id": "http://w3id.org/odrl/bcp47/en",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/source": [
      {
        "@id": "https://www.iso.org/standard/4766.html"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Base language concept for English (ISO 639-1: en). Linked to LCC authoritative URI via owl:sameAs. All regional and script variants of English are represented as narrower concepts (skos:broader)."
      }
    ],
    "http://www.w3.org/2002/07/owl#sameAs": [
      {
        "@id": "https://www.omg.org/spec/LCC/Languages/ISO639-1-LanguageCodes/English"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
