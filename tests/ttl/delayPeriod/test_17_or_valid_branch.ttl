@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix ex:   <http://example.org/> .
@prefix dct:  <http://purl.org/dc/terms/> .

# =============================================================================
# TEST 17: OR One Valid Branch
# =============================================================================
# Description: OR where at least one branch is satisfiable
# Scenario: "Valid if short delay (≤1 day) OR very long delay (≥1 year)"
# Expected: CONSISTENT
# Model: delayPeriod = 0 (immediate, satisfies branch 1)
# Analysis:
#   Branch 1: [0, 86400]      (≤1 day) - easily satisfiable, includes 0
#   Branch 2: [31536000, +∞)  (≥365 days) - also satisfiable
#   OR needs at least one
# =============================================================================

ex:policy_delay_period_17
    a odrl:Set ;
    dct:description "OR one valid branch: lteq 1D OR gteq 365D - both branches satisfiable"@en ;
    odrl:uid ex:policy_delay_period_17 ;
    odrl:permission [
        a odrl:Permission ;
        odrl:action odrl:distribute ;
        odrl:target ex:asset_17 ;
        odrl:constraint ex:constraint_17_or
    ] .

ex:constraint_17_or
    a odrl:Constraint ;
    odrl:or (ex:constraint_17a ex:constraint_17b) .

ex:constraint_17a
    a odrl:Constraint ;
    odrl:leftOperand odrl:delayPeriod ;
    odrl:operator odrl:lteq ;
    odrl:rightOperand "P1D"^^xsd:duration .

ex:constraint_17b
    a odrl:Constraint ;
    odrl:leftOperand odrl:delayPeriod ;
    odrl:operator odrl:gteq ;
    odrl:rightOperand "P365D"^^xsd:duration .
