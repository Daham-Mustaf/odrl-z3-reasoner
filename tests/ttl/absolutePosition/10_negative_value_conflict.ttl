@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix ex: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt: <http://qudt.org/vocab/unit/> .


# Test 10: Negative value CONFLICT
# Expected: CONFLICT/UNSATISFIABLE
# absolutePosition domain is [0,∞), so <0 is unsatisfiable

ex:policy01 a odrl:Set ;
    odrl:uid ex:policy01 ;
    odrl:permission [
        a odrl:Permission ;
        odrl:action odrl:play ;
        odrl:target ex:video01 ;
        odrl:constraint [
            a odrl:Constraint ;
            odrl:leftOperand odrl:absolutePosition ;
            odrl:operator odrl:lt ;
            odrl:rightOperand "0"^^xsd:decimal ;
            odrl:unit qudt:SEC
        ]
    ] .
