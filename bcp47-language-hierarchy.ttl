lang:en a skos:Concept ;
    dct:source <https://www.iso.org/standard/4766.html> ;
    rdfs:comment "Base language concept for English (ISO 639-1: en). Linked to LCC authoritative URI via owl:sameAs. All regional and script variants of English are represented as narrower concepts (skos:broader)."@en ;
    owl:sameAs lcc-639-1:English ;
    skos:inScheme lang:scheme ;
    skos:notation "en"^^xsd:language ;
    skos:note "This is an example of the base language pattern. All base languages follow this structure: skos:Concept with notation, prefLabel, owl:sameAs to LCC, and topConceptOf the scheme."@en ;
    skos:prefLabel "English"@en ;
    skos:topConceptOf lang:scheme .

lang:scheme a skos:ConceptScheme ;
    dct:description "Hierarchical organization of BCP47 language tags for ODRL constraint reasoning."@en ;
    dct:title "BCP47 Language Tags"@en .

