@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix ex:   <http://example.org/> .

# EXPECTED: POSSIBLY-COMPATIBLE
# Reason: OR(AND(unsat), AND(sat)) = sat
# First AND branch: count < 0 AND count > 10 = UNSAT
# Second AND branch: count >= 1 AND count <= 5 = SAT (e.g., count = 3)

ex:policy a odrl:Set ;
  odrl:permission [
    odrl:action odrl:use ;
    odrl:constraint ex:or_constraint
  ] .

# Top level OR
ex:or_constraint a odrl:LogicalConstraint ;
  odrl:or ex:and1, ex:and2 .

# First AND (UNSAT)
ex:and1 a odrl:LogicalConstraint ;
  odrl:and ex:c1, ex:c2 .

ex:c1 a odrl:Constraint ;
  odrl:leftOperand odrl:count ;
  odrl:operator odrl:lt ;
  odrl:rightOperand "0"^^xsd:integer .

ex:c2 a odrl:Constraint ;
  odrl:leftOperand odrl:count ;
  odrl:operator odrl:gt ;
  odrl:rightOperand "10"^^xsd:integer .

# Second AND (SAT)
ex:and2 a odrl:LogicalConstraint ;
  odrl:and ex:c3, ex:c4 .

ex:c3 a odrl:Constraint ;
  odrl:leftOperand odrl:count ;
  odrl:operator odrl:gteq ;
  odrl:rightOperand "1"^^xsd:integer .

ex:c4 a odrl:Constraint ;
  odrl:leftOperand odrl:count ;
  odrl:operator odrl:lteq ;
  odrl:rightOperand "5"^^xsd:integer .
