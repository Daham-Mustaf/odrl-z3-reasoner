    dct:spatial lcc-3166-1:China ;
    rdfs:comment "Chinese (Simplified, China) is a complex tag combining script and region. Multi-level hierarchy: zh-Hans-CN → zh-Hans → zh. Per BCP47, complex tags are built by adding subtags to existing variants."@en ;
    skos:broader lang:zh-Hans ;
    skos:inScheme lang:scheme ;
    skos:notation "zh-Hans-CN"^^xsd:language ;
    skos:prefLabel "Chinese (Simplified, China)"@en .

