@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix ex: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt: <http://qudt.org/vocab/unit/> .
# Test 37: resolution REDUNDANCY subsumed
# Expected: REDUNDANT (≤300 subsumes ≤600, so ≤600 is redundant)
# ≤300 AND ≤600 = ≤300 (≤600 adds nothing)

ex:policy01 a odrl:Set ;
    odrl:uid ex:policy01 ;
    odrl:permission [
        a odrl:Permission ;
        odrl:action odrl:print ;
        odrl:target ex:asset01 ;
        odrl:constraint [
            a odrl:LogicalConstraint ;
            odrl:and (
                [
                    a odrl:Constraint ;
                    odrl:leftOperand odrl:resolution ;
                    odrl:operator odrl:lteq ;
                    odrl:rightOperand "300"^^xsd:decimal ;
                    odrl:unit qudt:DPI
                ]
                [
                    a odrl:Constraint ;
                    odrl:leftOperand odrl:resolution ;
                    odrl:operator odrl:lteq ;
                    odrl:rightOperand "600"^^xsd:decimal ;
                    odrl:unit qudt:DPI
                ]
            )
        ]
    ] .
