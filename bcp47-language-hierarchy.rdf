  <rdf:Description rdf:about="http://w3id.org/odrl/bcp47/en">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:notation rdf:datatype="http://www.w3.org/2001/XMLSchema#language">en</skos:notation>
    <skos:prefLabel xml:lang="en">English</skos:prefLabel>
    <skos:inScheme rdf:resource="http://w3id.org/odrl/bcp47/scheme"/>
    <skos:topConceptOf rdf:resource="http://w3id.org/odrl/bcp47/scheme"/>
    <owl:sameAs rdf:resource="https://www.omg.org/spec/LCC/Languages/ISO639-1-LanguageCodes/English"/>
    <dct:source rdf:resource="https://www.iso.org/standard/4766.html"/>
    <rdfs:comment xml:lang="en">Base language concept for English (ISO 639-1: en). Linked to LCC authoritative URI via owl:sameAs. All regional and script variants of English are represented as narrower concepts (skos:broader).</rdfs:comment>
    <skos:note xml:lang="en">This is an example of the base language pattern. All base languages follow this structure: skos:Concept with notation, prefLabel, owl:sameAs to LCC, and topConceptOf the scheme.</skos:note>
  </rdf:Description>
  <rdf:Description rdf:about="http://w3id.org/odrl/bcp47/en-US">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:notation rdf:datatype="http://www.w3.org/2001/XMLSchema#language">en-US</skos:notation>
    <skos:prefLabel xml:lang="en">English (United States)</skos:prefLabel>
    <skos:inScheme rdf:resource="http://w3id.org/odrl/bcp47/scheme"/>
    <skos:broader rdf:resource="http://w3id.org/odrl/bcp47/en"/>
    <dct:language rdf:resource="https://www.omg.org/spec/LCC/Languages/ISO639-1-LanguageCodes/English"/>
    <dct:spatial rdf:resource="https://www.omg.org/spec/LCC/Countries/ISO3166-1-CountryCodes/UnitedStates"/>
    <dct:source rdf:resource="https://www.rfc-editor.org/rfc/rfc5646#section-2.2.4"/>
    <rdfs:comment xml:lang="en">English (United States) is a regional variant of English. Per BCP47 (RFC 5646, Section 2.2.4), regional subtags (ISO 3166-1) specialize the primary language by geographic usage. The hierarchy 'en-US skos:broader en' represents that US variant is a more specific form of the base language.</rdfs:comment>
    <skos:note xml:lang="en">BCP47 tag decomposed into components: language 'en' (ISO 639-1) → lcc-639-1:English, region 'US' (ISO 3166-1) → lcc-3166-1:UnitedStates. This component pattern applies to all [language]-[region] tags in this ontology.</skos:note>
  </rdf:Description>
