@prefix odrl: <http://www.w3.org/ns/odrl/2/\> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema\#\> .
@prefix ex: <http://example.org/\> .

# Parent: permit use when (time < 10)
# Child:  permit use when (time < 10 OR count < 20)
# Expected: EXPANSION VIOLATION

ex:parent_policy a odrl:Policy ;
    odrl:permission [
        odrl:action odrl:use ;
        odrl:constraint ex:parent_constraint
    ] .

ex:parent_constraint a odrl:Constraint ;
    odrl:leftOperand odrl:elapsedTime ;
    odrl:operator odrl:lt ;
    odrl:rightOperand "10"^^xsd:integer .

ex:child_policy a odrl:Policy ;
    odrl:inheritFrom ex:parent_policy ;
    odrl:permission [
        odrl:action odrl:use ;
        odrl:constraint ex:child_or
    ] .

ex:child_or a odrl:LogicalConstraint ;
    odrl:or ex:c1, ex:c2 .

ex:c1 a odrl:Constraint ;
    odrl:leftOperand odrl:elapsedTime ;
    odrl:operator odrl:lt ;
    odrl:rightOperand "10"^^xsd:integer .

ex:c2 a odrl:Constraint ;
    odrl:leftOperand odrl:count ;
    odrl:operator odrl:lt ;
    odrl:rightOperand "20"^^xsd:integer .
