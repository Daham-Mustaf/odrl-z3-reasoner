@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ex: <http://example.org/> .

ex:policy_time_conflict a odrl:Policy ;

  odrl:permission [
    odrl:action odrl:use ;
    odrl:constraint [
      odrl:leftOperand odrl:dateTimeAfter ;
      odrl:operator odrl:gt ;
      odrl:rightOperand "2025-01-01T00:00:00Z"^^xsd:dateTime
    ]
  ] ;

  odrl:prohibition [
    odrl:action odrl:use ;
    odrl:constraint [
      odrl:leftOperand odrl:dateTimeBefore ;
      odrl:operator odrl:lt ;
      odrl:rightOperand "2025-12-31T23:59:59Z"^^xsd:dateTime
    ]
  ] .
