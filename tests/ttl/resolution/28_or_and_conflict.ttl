@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix ex: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt: <http://qudt.org/vocab/unit/> .

# Test 28: resolution OR with AND CONFLICT
# Expected: CONFLICT
# (≤72 OR =300) AND >300 = empty
# Branch 1: ≤72 AND >300 = ∅
# Branch 2: =300 AND >300 = ∅

ex:policy01 a odrl:Set ;
    odrl:uid ex:policy01 ;
    odrl:permission [
        a odrl:Permission ;
        odrl:action odrl:print ;
        odrl:target ex:asset01 ;
        odrl:constraint [
            a odrl:LogicalConstraint ;
            odrl:and (
                [
                    a odrl:LogicalConstraint ;
                    odrl:or (
                        [
                            a odrl:Constraint ;
                            odrl:leftOperand odrl:resolution ;
                            odrl:operator odrl:lteq ;
                            odrl:rightOperand "72"^^xsd:decimal ;
                            odrl:unit qudt:DPI
                        ]
                        [
                            a odrl:Constraint ;
                            odrl:leftOperand odrl:resolution ;
                            odrl:operator odrl:eq ;
                            odrl:rightOperand "300"^^xsd:decimal ;
                            odrl:unit qudt:DPI
                        ]
                    )
                ]
                [
                    a odrl:Constraint ;
                    odrl:leftOperand odrl:resolution ;
                    odrl:operator odrl:gt ;
                    odrl:rightOperand "300"^^xsd:decimal ;
                    odrl:unit qudt:DPI
                ]
            )
        ]
    ] .
