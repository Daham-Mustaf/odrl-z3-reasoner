@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix ex: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt: <http://qudt.org/vocab/unit/> .

# Test 11: Complex valid range CONSISTENT
# Expected: CONSISTENT
# (≥50 AND ≤200) AND (≥100 AND ≤150) = [100,150]

ex:policy01 a odrl:Set ;
    odrl:uid ex:policy01 ;
    odrl:permission [
        a odrl:Permission ;
        odrl:action odrl:use ;
        odrl:target ex:asset01 ;
        odrl:constraint [
            a odrl:LogicalConstraint ;
            odrl:and (
                [
                    a odrl:LogicalConstraint ;
                    odrl:and (
                        [
                            a odrl:Constraint ;
                            odrl:leftOperand odrl:payAmount ;
                            odrl:operator odrl:gteq ;
                            odrl:rightOperand "50"^^xsd:decimal ;
                            odrl:unit qudt:EUR
                        ]
                        [
                            a odrl:Constraint ;
                            odrl:leftOperand odrl:payAmount ;
                            odrl:operator odrl:lteq ;
                            odrl:rightOperand "200"^^xsd:decimal ;
                            odrl:unit qudt:EUR
                        ]
                    )
                ]
                [
                    a odrl:LogicalConstraint ;
                    odrl:and (
                        [
                            a odrl:Constraint ;
                            odrl:leftOperand odrl:payAmount ;
                            odrl:operator odrl:gteq ;
                            odrl:rightOperand "100"^^xsd:decimal ;
                            odrl:unit qudt:EUR
                        ]
                        [
                            a odrl:Constraint ;
                            odrl:leftOperand odrl:payAmount ;
                            odrl:operator odrl:lteq ;
                            odrl:rightOperand "150"^^xsd:decimal ;
                            odrl:unit qudt:EUR
                        ]
                    )
                ]
            )
        ]
    ] .
