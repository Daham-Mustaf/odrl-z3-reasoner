# =============================================================================
# Security and Protection Purposes
# =============================================================================

dpv:CounterMoneyLaundering a skos:Concept, dpv:Purpose ;
    rdfs:label "Counter Money Laundering"@en ;
    skos:definition "Purposes associated with countering money laundering."@en ;
    skos:broader dpv:FraudPreventionAndDetection ;
    skos:inScheme <https://w3id.org/dpv/purposes> .

dpv:Counterterrorism a skos:Concept, dpv:Purpose ;
    rdfs:label "Counterterrorism"@en ;
    skos:definition "Purposes associated with counterterrorism."@en ;
    skos:broader dpv:EnforceSecurity ;
    skos:inScheme <https://w3id.org/dpv/purposes> .

dpv:MisusePreventionAndDetection a skos:Concept, dpv:Purpose ;
    rdfs:label "Misuse Prevention and Detection"@en ;
    skos:definition "Purposes associated with preventing and detecting misuse."@en ;
    skos:broader dpv:EnforceSecurity ;
    skos:inScheme <https://w3id.org/dpv/purposes> .

dpv:ProtectionOfIPR a skos:Concept, dpv:Purpose ;
    rdfs:label "Protection of Intellectual Property Rights"@en ;
    skos:definition "Purposes associated with protecting intellectual property rights."@en ;
    skos:broader dpv:EnforceSecurity ;
    skos:inScheme <https://w3id.org/dpv/purposes> .

dpv:ProtectionOfNationalSecurity a skos:Concept, dpv:Purpose ;
    rdfs:label "Protection of National Security"@en ;
    skos:definition "Purposes associated with protecting national security."@en ;
    skos:broader dpv:EnforceSecurity ;
    skos:inScheme <https://w3id.org/dpv/purposes> .

dpv:ProtectionOfPublicSecurity a skos:Concept, dpv:Purpose ;
    rdfs:label "Protection of Public Security"@en ;
    skos:definition "Purposes associated with protecting public security."@en ;
    skos:broader dpv:EnforceSecurity ;
    skos:inScheme <https://w3id.org/dpv/purposes> .

# =============================================================================
# Additional ODRL-relevant aliases (common terms mapped to DPV)
# =============================================================================

# These provide skos:exactMatch to common ODRL purpose terms
dpv:Education a skos:Concept, dpv:Purpose ;
    rdfs:label "Education"@en ;
    skos:definition "Purposes associated with education."@en ;
    skos:broader dpv:NonCommercialPurpose ;
    skos:exactMatch <http://www.w3.org/ns/odrl/2/education> ;
    skos:inScheme <https://w3id.org/dpv/purposes> .

dpv:Research a skos:Concept, dpv:Purpose ;
    rdfs:label "Research"@en ;
    skos:definition "Purposes associated with research."@en ;
    skos:broader dpv:ResearchAndDevelopment ;
    skos:exactMatch <http://www.w3.org/ns/odrl/2/research> ;
    skos:inScheme <https://w3id.org/dpv/purposes> .
