@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix ex: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt: <http://qudt.org/vocab/unit/> .

# Test 30: resolution XONE with OVERLAP
# Expected: CONSISTENT but restricted
# XONE(≤300, ≥150) - overlap at [150,300], only non-overlap satisfies xone
# Valid: (0,150) where only first is true, OR (300,∞) where only second is true

ex:policy01 a odrl:Set ;
    odrl:uid ex:policy01 ;
    odrl:permission [
        a odrl:Permission ;
        odrl:action odrl:print ;
        odrl:target ex:asset01 ;
        odrl:constraint [
            a odrl:LogicalConstraint ;
            odrl:xone (
                [
                    a odrl:Constraint ;
                    odrl:leftOperand odrl:resolution ;
                    odrl:operator odrl:lteq ;
                    odrl:rightOperand "300"^^xsd:decimal ;
                    odrl:unit qudt:DPI
                ]
                [
                    a odrl:Constraint ;
                    odrl:leftOperand odrl:resolution ;
                    odrl:operator odrl:gteq ;
                    odrl:rightOperand "150"^^xsd:decimal ;
                    odrl:unit qudt:DPI
                ]
            )
        ]
    ] .
