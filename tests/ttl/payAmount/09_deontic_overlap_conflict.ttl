@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix ex: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt: <http://qudt.org/vocab/unit/> .

# Test 09: Deontic CONFLICT
# Expected: DEONTIC-CONFLICT
# Permission: ≤100 EUR, Prohibition: ≤50 EUR
# Overlap at [0,50] is both permitted and prohibited

ex:policy01 a odrl:Set ;
    odrl:uid ex:policy01 ;
    odrl:permission [
        a odrl:Permission ;
        odrl:action odrl:use ;
        odrl:target ex:asset01 ;
        odrl:constraint [
            a odrl:Constraint ;
            odrl:leftOperand odrl:payAmount ;
            odrl:operator odrl:lteq ;
            odrl:rightOperand "100"^^xsd:decimal ;
            odrl:unit qudt:EUR
        ]
    ] ;
    odrl:prohibition [
        a odrl:Prohibition ;
        odrl:action odrl:use ;
        odrl:target ex:asset01 ;
        odrl:constraint [
            a odrl:Constraint ;
            odrl:leftOperand odrl:payAmount ;
            odrl:operator odrl:lteq ;
            odrl:rightOperand "50"^^xsd:decimal ;
            odrl:unit qudt:EUR
        ]
    ] .
