@prefix lang: <http://w3id.org/odrl/bcp47/lang/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix lcc-639-1: <https://www.omg.org/spec/LCC/Languages/ISO639-1-LanguageCodes/> .
@prefix lcc-3166-1: <https://www.omg.org/spec/LCC/Countries/ISO3166-1-CountryCodes/> .
@prefix lcc-15924: <https://www.omg.org/spec/LCC/Languages/ISO15924-CodeSet/> .

<http://w3id.org/odrl/bcp47> a owl:Ontology ;
    dct:title "BCP47 Language Tag Hierarchy for ODRL Policy Reasoning"@en ;
    dct:created "2026-01-26"^^xsd:date ;
    rdfs:comment "Base language concepts include ISO 639-1 (2-letter) and ISO 639-3 (3-letter) codes as defined by the IANA Language Subtag Registry. Only ISO 639-1 codes have skos:exactMatch links to LCC."@en ;
    dct:description """
Semantic grounding for ODRL language constraints (odrl:language)
by mapping BCP47 language tags to SKOS concepts with hierarchical relationships.

DESIGN PRINCIPLES:
1. Zero new vocabulary - reuses only SKOS, OWL, Dublin Core, LCC
2. Hierarchy via skos:broader (derived from RFC 5646 composition rules)
3. Equivalence via skos:exactMatch (not owl:sameAs)
4. Disjointness is DERIVED, not asserted

STANDARDS REUSED:
- SKOS (W3C): Taxonomy structure
- OWL (W3C): Ontology declaration
- Dublin Core: Metadata
- LCC (OMG): Authoritative URIs for ISO codes
"""@en ;
    dct:source <https://www.rfc-editor.org/rfc/rfc5646> ,
               <https://www.iso.org/iso-639-language-codes.html> ,
               <https://www.omg.org/spec/LCC/> ;
    rdfs:comment "Generated by ODRL-SA Language Ontology Builder"@en ;
    owl:versionInfo "1.0" .

lang:scheme a skos:ConceptScheme ;
    dct:title "BCP47 Language Tags"@en ;
    dct:description "Hierarchical organization of BCP47 language tags for ODRL constraint reasoning."@en ;
    skos:note "Hierarchy: specific tags (e.g., en-US) have skos:broader links to more general tags (e.g., en). Base languages are skos:topConceptOf this scheme."@en .

lang:aa a skos:Concept ;
