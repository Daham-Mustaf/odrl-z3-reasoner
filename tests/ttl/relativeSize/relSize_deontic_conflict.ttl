@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix ex:   <http://example.org/> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

ex:policy_deontic_conflict
    a odrl:Set ;
    odrl:permission ex:perm1 ;
    odrl:prohibition ex:prohib1 .

ex:perm1
    a odrl:Permission ;
    odrl:action odrl:display ;
    odrl:constraint ex:c_perm .

ex:prohib1
    a odrl:Prohibition ;
    odrl:action odrl:display ;
    odrl:constraint ex:c_prohib .

ex:c_perm
    a odrl:Constraint ;
    odrl:leftOperand odrl:relativeSize ;
    odrl:operator odrl:gteq ;
    odrl:rightOperand "100"^^xsd:decimal .

ex:c_prohib
    a odrl:Constraint ;
    odrl:leftOperand odrl:relativeSize ;
    odrl:operator odrl:lteq ;
    odrl:rightOperand "150"^^xsd:decimal .
