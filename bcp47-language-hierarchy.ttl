lang:en-US a skos:Concept ;
    dct:language lcc-639-1:English ;
    dct:source <https://www.rfc-editor.org/rfc/rfc5646#section-2.2.4> ;
    dct:spatial lcc-3166-1:UnitedStates ;
    rdfs:comment "English (United States) is a regional variant of English. Per BCP47 (RFC 5646, Section 2.2.4), regional subtags (ISO 3166-1) specialize the primary language by geographic usage. The hierarchy 'en-US skos:broader en' represents that US variant is a more specific form of the base language."@en ;
    skos:broader lang:en ;
    skos:inScheme lang:scheme ;
    skos:notation "en-US"^^xsd:language ;
    skos:note "BCP47 tag decomposed into components: language 'en' (ISO 639-1) → lcc-639-1:English, region 'US' (ISO 3166-1) → lcc-3166-1:UnitedStates. This component pattern applies to all [language]-[region] tags in this ontology."@en ;
    skos:prefLabel "English (United States)"@en .

