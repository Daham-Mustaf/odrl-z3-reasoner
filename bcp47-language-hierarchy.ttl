lang:zh-Hans a skos:Concept ;
    dct:conformsTo lcc-15924:Hans ;
    dct:language lcc-639-1:Chinese ;
    dct:source <https://www.rfc-editor.org/rfc/rfc5646#section-2.2.3> ;
    rdfs:comment "Chinese (Simplified) is a script variant of ZH. Per BCP47 (RFC 5646, Section 2.2.3), script subtags (ISO 15924) specialize a language by writing system. The 'Hans' script (Simplified Han script) distinguishes this variant from other writing systems of the same language."@en ;
    skos:broader lang:zh ;
    skos:inScheme lang:scheme ;
    skos:notation "zh-Hans"^^xsd:language ;
    skos:prefLabel "Chinese (Simplified)"@en .

