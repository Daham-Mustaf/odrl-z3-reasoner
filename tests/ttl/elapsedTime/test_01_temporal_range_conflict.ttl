@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix ex:   <http://example.org/> .
@prefix dct:  <http://purl.org/dc/terms/> .

# =============================================================================
# TEST 01: Temporal Range Conflict
# =============================================================================
# Description: elapsedTime must be ≤30 minutes AND ≥60 minutes (impossible)
# Scenario: "License valid for first 30 minutes AND only after 60 minutes"
# Expected: CONFLICT
# Reason: No duration can be ≤30min AND ≥60min simultaneously
# Analysis:
#   α(lteq 1800) = (0, 1800]
#   α(gteq 3600) = [3600, +∞)
#   Meet: (0, 1800] ∩ [3600, +∞) = ∅
# =============================================================================

ex:policy_elapsed_time_01
    a odrl:Set ;
    dct:description "Temporal range conflict: ≤30min AND ≥60min is impossible"@en ;
    odrl:uid ex:policy_elapsed_time_01 ;
    odrl:permission [
        a odrl:Permission ;
        odrl:action odrl:use ;
        odrl:target ex:asset_01 ;
        odrl:constraint ex:constraint_01_composite
    ] .

ex:constraint_01_composite
    a odrl:Constraint ;
    odrl:and (ex:constraint_01a ex:constraint_01b) .

ex:constraint_01a
    a odrl:Constraint ;
    odrl:leftOperand odrl:elapsedTime ;
    odrl:operator odrl:lteq ;
    odrl:rightOperand "PT30M"^^xsd:duration .

ex:constraint_01b
    a odrl:Constraint ;
    odrl:leftOperand odrl:elapsedTime ;
    odrl:operator odrl:gteq ;
    odrl:rightOperand "PT60M"^^xsd:duration .
