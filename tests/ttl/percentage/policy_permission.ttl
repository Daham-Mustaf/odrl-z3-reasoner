@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix ex:   <http://example.org/> .

ex:policy a odrl:Set ;
  odrl:permission [
    odrl:action odrl:use ;
    odrl:constraint ex:p_or ;
  ] .

# percentage <= 50 OR percentage >= 90
ex:p1 a odrl:Constraint ;
  odrl:leftOperand odrl:percentage ;
  odrl:operator odrl:lteq ;
  odrl:rightOperand "50"^^xsd:decimal .

ex:p2 a odrl:Constraint ;
  odrl:leftOperand odrl:percentage ;
  odrl:operator odrl:gteq ;
  odrl:rightOperand "90"^^xsd:decimal .

ex:p_or a odrl:LogicalConstraint ;
  odrl:or (ex:p1 ex:p2) .
