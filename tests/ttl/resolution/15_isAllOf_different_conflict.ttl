
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix ex: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt: <http://qudt.org/vocab/unit/> .

# Test 15: resolution isAllOf CONFLICT (different values)
# Expected: CONFLICT (isAllOf [72, 150, 300] is impossible - can't equal all three)

ex:policy01 a odrl:Set ;
    odrl:uid ex:policy01 ;
    odrl:permission [
        a odrl:Permission ;
        odrl:action odrl:print ;
        odrl:target ex:asset01 ;
        odrl:constraint [
            a odrl:Constraint ;
            odrl:leftOperand odrl:resolution ;
            odrl:operator odrl:isAllOf ;
            odrl:rightOperand ( "72"^^xsd:decimal "150"^^xsd:decimal "300"^^xsd:decimal ) ;
            odrl:unit qudt:DPI
        ]
    ] .