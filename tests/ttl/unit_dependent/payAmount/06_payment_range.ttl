@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt: <http://qudt.org/vocab/unit/> .
@prefix ex: <http://example.org/> .

# TEST: Valid payment range → POSSIBLY-COMPATIBLE
# c1: payAmount gteq 10 EUR (minimum)
# c2: payAmount lteq 100 EUR (maximum)
# c3: payAmount neq 50 EUR (exclude specific)
# Expected: POSSIBLY-COMPATIBLE (e.g., 25 EUR satisfies all)

ex:policy a odrl:Set ;
    odrl:uid ex:policy ;
    odrl:permission ex:perm1 .

ex:perm1 a odrl:Permission ;
    odrl:action odrl:use ;
    odrl:constraint ex:c1, ex:c2, ex:c3 .

ex:c1 a odrl:Constraint ;
    odrl:uid ex:c1 ;
    odrl:leftOperand odrl:payAmount ;
    odrl:operator odrl:gteq ;
    odrl:rightOperand "10.00"^^xsd:decimal ;
    odrl:unit qudt:EUR .

ex:c2 a odrl:Constraint ;
    odrl:uid ex:c2 ;
    odrl:leftOperand odrl:payAmount ;
    odrl:operator odrl:lteq ;
    odrl:rightOperand "100.00"^^xsd:decimal ;
    odrl:unit qudt:EUR .

ex:c3 a odrl:Constraint ;
    odrl:uid ex:c3 ;
    odrl:leftOperand odrl:payAmount ;
    odrl:operator odrl:neq ;
    odrl:rightOperand "50.00"^^xsd:decimal ;
    odrl:unit qudt:EUR .