@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix ex: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Test 15: XONE disjoint CONSISTENT
# Expected: CONSISTENT
# XONE(≤30 intro, ≥570 outro) - disjoint ranges for 10-min video

ex:policy01 a odrl:Set ;
    odrl:uid ex:policy01 ;
    odrl:permission [
        a odrl:Permission ;
        odrl:action odrl:play ;
        odrl:target ex:video01 ;
        odrl:constraint [
            a odrl:LogicalConstraint ;
            odrl:xone (
                [
                    a odrl:Constraint ;
                    odrl:leftOperand odrl:absoluteTemporalPosition ;
                    odrl:operator odrl:lteq ;
                    odrl:rightOperand "30"^^xsd:decimal
                ]
                [
                    a odrl:Constraint ;
                    odrl:leftOperand odrl:absoluteTemporalPosition ;
                    odrl:operator odrl:gteq ;
                    odrl:rightOperand "570"^^xsd:decimal
                ]
            )
        ]
    ] .
