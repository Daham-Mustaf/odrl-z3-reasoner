        "@type": "http://www.w3.org/2001/XMLSchema#language",
        "@value": "en"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#note": [
      {
        "@language": "en",
        "@value": "This is an example of the base language pattern. All base languages follow this structure: skos:Concept with notation, prefLabel, owl:sameAs to LCC, and topConceptOf the scheme."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
