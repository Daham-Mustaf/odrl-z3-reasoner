@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix ex:   <http://example.org/> .

# EXPECTED: CONFLICT
# Reason: percentage < 0 violates domain constraint (percentage >= 0)
#   Domain: [0, 100]
#   Constraint: percentage < 0 → no valid values

ex:policy a odrl:Set ;
  odrl:permission [
    odrl:action odrl:use ;
    odrl:constraint ex:c1
  ] .

ex:c1 a odrl:Constraint ;
  odrl:leftOperand odrl:percentage ;
  odrl:operator odrl:lt ;
  odrl:rightOperand "0"^^xsd:decimal .
