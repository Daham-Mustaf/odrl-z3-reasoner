@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt: <http://qudt.org/vocab/unit/> .
@prefix ex: <http://example.org/> .

# TEST: Different units (SEC vs BYTE) → UNKNOWN
# c1: absolutePosition lteq 30 SEC (time-based)
# c2: absolutePosition gteq 1000 BYTE (byte offset)
# Expected: UNKNOWN (incompatible units)

ex:policy a odrl:Set ;
    odrl:uid ex:policy ;
    odrl:permission ex:perm1 .

ex:perm1 a odrl:Permission ;
    odrl:action odrl:play ;
    odrl:constraint ex:c1, ex:c2 .

ex:c1 a odrl:Constraint ;
    odrl:uid ex:c1 ;
    odrl:leftOperand odrl:absolutePosition ;
    odrl:operator odrl:lteq ;
    odrl:rightOperand "30"^^xsd:decimal ;
    odrl:unit qudt:SEC .

ex:c2 a odrl:Constraint ;
    odrl:uid ex:c2 ;
    odrl:leftOperand odrl:absolutePosition ;
    odrl:operator odrl:gteq ;
    odrl:rightOperand "1000"^^xsd:decimal ;
    odrl:unit qudt:BYTE .