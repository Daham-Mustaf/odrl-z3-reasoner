@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix ex:   <http://example.org/> .
@prefix dct:  <http://purl.org/dc/terms/> .

# =============================================================================
# TEST 15: isNoneOf with Valid Remainder
# =============================================================================
# Description: Exclude specific times but allow others in range
# Scenario: "No access at exactly 1 or 2 hours, but other times OK"
# Expected: CONSISTENT
# Model: elapsedTime = 5400 (90 minutes)
# Analysis:
#   Range: [1800, 10800]  (30min to 3h)
#   Excluded: {3600, 7200}  (1h and 2h)
#   Valid: [1800, 10800] \ {3600, 7200} ≠ ∅
# =============================================================================

ex:policy_elapsed_time_15
    a odrl:Set ;
    dct:description "isNoneOf with valid remainder: exclude 1h and 2h but allow other times in 30min-3h range"@en ;
    odrl:uid ex:policy_elapsed_time_15 ;
    odrl:permission [
        a odrl:Permission ;
        odrl:action odrl:use ;
        odrl:target ex:asset_15 ;
        odrl:constraint ex:constraint_15_composite
    ] .

ex:constraint_15_composite
    a odrl:Constraint ;
    odrl:and (ex:constraint_15a ex:constraint_15b ex:constraint_15c) .

ex:constraint_15a
    a odrl:Constraint ;
    odrl:leftOperand odrl:elapsedTime ;
    odrl:operator odrl:isNoneOf ;
    odrl:rightOperand ("PT1H"^^xsd:duration "PT2H"^^xsd:duration) .

ex:constraint_15b
    a odrl:Constraint ;
    odrl:leftOperand odrl:elapsedTime ;
    odrl:operator odrl:gteq ;
    odrl:rightOperand "PT30M"^^xsd:duration .

ex:constraint_15c
    a odrl:Constraint ;
    odrl:leftOperand odrl:elapsedTime ;
    odrl:operator odrl:lteq ;
    odrl:rightOperand "PT3H"^^xsd:duration .
