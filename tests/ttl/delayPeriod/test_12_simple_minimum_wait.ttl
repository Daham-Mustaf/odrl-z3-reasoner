@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix ex:   <http://example.org/> .
@prefix dct:  <http://purl.org/dc/terms/> .

# =============================================================================
# TEST 12: Simple Minimum Wait (Typical Pattern)
# =============================================================================
# Description: delayPeriod at least 30 days (most common pattern)
# Scenario: "30-day embargo before distribution"
# Expected: CONSISTENT
# Model: delayPeriod = 2592000 (30 days)
# Analysis:
#   α(gteq 2592000) = [2592000, +∞)
#   Domain: [0, +∞)
#   Domain satisfied
#
# Note: This is the TYPICAL usage pattern for delayPeriod
#       "Must wait AT LEAST this long before action is allowed"
# =============================================================================

ex:policy_delay_period_12
    a odrl:Set ;
    dct:description "Simple minimum wait: 30-day embargo before distribution (typical pattern)"@en ;
    odrl:uid ex:policy_delay_period_12 ;
    odrl:permission [
        a odrl:Permission ;
        odrl:action odrl:distribute ;
        odrl:target ex:asset_12 ;
        odrl:constraint ex:constraint_12
    ] .

ex:constraint_12
    a odrl:Constraint ;
    odrl:leftOperand odrl:delayPeriod ;
    odrl:operator odrl:gteq ;
    odrl:rightOperand "P30D"^^xsd:duration .
