@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix ex:   <http://example.org/> .

ex:policy3 a odrl:Set ;
  odrl:permission ex:perm1 .

ex:perm1 a odrl:Permission ;
  odrl:action odrl:display ;
  odrl:constraint ex:orC .

ex:orC a odrl:Constraint ;
  odrl:or ( ex:c1 ex:c2 ) .

ex:c1 a odrl:Constraint ;
  odrl:leftOperand odrl:relativePosition ;
  odrl:operator odrl:lt ;
  odrl:rightOperand "10"^^xsd:decimal .

ex:c2 a odrl:Constraint ;
  odrl:leftOperand odrl:relativePosition ;
  odrl:operator odrl:gt ;
  odrl:rightOperand "90"^^xsd:decimal .
