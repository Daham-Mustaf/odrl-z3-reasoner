@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt: <http://qudt.org/vocab/unit/> .
@prefix ex: <http://example.org/> .

# TEST: File byte range (for partial download)
# c1: absolutePosition gteq 0 BYTE (from start)
# c2: absolutePosition lteq 1048576 BYTE (first 1 MB only)
# Expected: POSSIBLY-COMPATIBLE

ex:policy a odrl:Set ;
    odrl:uid ex:policy ;
    odrl:permission ex:perm1 .

ex:perm1 a odrl:Permission ;
    odrl:action odrl:read ;
    odrl:constraint ex:c1, ex:c2 .

ex:c1 a odrl:Constraint ;
    odrl:uid ex:c1 ;
    odrl:leftOperand odrl:absolutePosition ;
    odrl:operator odrl:gteq ;
    odrl:rightOperand "0"^^xsd:decimal ;
    odrl:unit qudt:BYTE .

ex:c2 a odrl:Constraint ;
    odrl:uid ex:c2 ;
    odrl:leftOperand odrl:absolutePosition ;
    odrl:operator odrl:lteq ;
    odrl:rightOperand "1048576"^^xsd:decimal ;
    odrl:unit qudt:BYTE .