@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix ex:   <http://example.org/> .
@prefix dct:  <http://purl.org/dc/terms/> .

# =============================================================================
# TEST 16: XONE Disjoint Valid
# =============================================================================
# Description: Exactly one of two non-overlapping delay options
# Scenario: "Either short embargo (≤7 days) OR long embargo (≥30 days)"
# Expected: CONSISTENT
# Model: delayPeriod = 259200 (3 days, satisfies branch 1 only)
# Analysis:
#   Branch 1: [0, 604800]     (≤7 days)
#   Branch 2: [2592000, +∞)   (≥30 days)
#   No overlap - exactly one can be true for any value
# =============================================================================

ex:policy_delay_period_16
    a odrl:Set ;
    dct:description "XONE disjoint valid: exactly one of short (≤7D) or long (≥30D) embargo"@en ;
    odrl:uid ex:policy_delay_period_16 ;
    odrl:permission [
        a odrl:Permission ;
        odrl:action odrl:distribute ;
        odrl:target ex:asset_16 ;
        odrl:constraint ex:constraint_16_xone
    ] .

ex:constraint_16_xone
    a odrl:Constraint ;
    odrl:xone (ex:constraint_16a ex:constraint_16b) .

ex:constraint_16a
    a odrl:Constraint ;
    odrl:leftOperand odrl:delayPeriod ;
    odrl:operator odrl:lteq ;
    odrl:rightOperand "P7D"^^xsd:duration .

ex:constraint_16b
    a odrl:Constraint ;
    odrl:leftOperand odrl:delayPeriod ;
    odrl:operator odrl:gteq ;
    odrl:rightOperand "P30D"^^xsd:duration .
