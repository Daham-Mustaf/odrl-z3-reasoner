@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix ex: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt: <http://qudt.org/vocab/unit/> .


# Test 02: Zero size CONFLICT
# Expected: CONFLICT/UNSATISFIABLE
# absoluteSize domain is (0,∞), so ≤0 is unsatisfiable

ex:policy01 a odrl:Set ;
    odrl:uid ex:policy01 ;
    odrl:permission [
        a odrl:Permission ;
        odrl:action odrl:display ;
        odrl:target ex:image01 ;
        odrl:constraint [
            a odrl:Constraint ;
            odrl:leftOperand odrl:absoluteSize ;
            odrl:operator odrl:lteq ;
            odrl:rightOperand "0"^^xsd:decimal ;
            odrl:unit qudt:PX
        ]
    ] .
