@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix ex: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# Test 2: Inconsistent Child (Child contradicts parent)
# Parent: count <= 50
# Child:  count >= 100  (VIOLATION - no overlap!)
# Combined: count <= 50 AND count >= 100 = UNSAT
# =============================================================================

ex:parentPolicy a odrl:Set ;
    odrl:uid ex:parentPolicy ;
    odrl:permission [
        a odrl:Permission ;
        odrl:uid ex:parentPerm ;
        odrl:action odrl:use ;
        odrl:constraint ex:parentConstraint
    ] .

ex:parentConstraint a odrl:Constraint ;
    odrl:leftOperand odrl:count ;
    odrl:operator odrl:lteq ;
    odrl:rightOperand "50"^^xsd:integer .

ex:childPolicy a odrl:Set ;
    odrl:uid ex:childPolicy ;
    odrl:inheritFrom ex:parentPolicy ;
    odrl:permission [
        a odrl:Permission ;
        odrl:uid ex:childPerm ;
        odrl:action odrl:use ;
        odrl:constraint ex:childConstraint
    ] .

ex:childConstraint a odrl:Constraint ;
    odrl:leftOperand odrl:count ;
    odrl:operator odrl:gteq ;
    odrl:rightOperand "100"^^xsd:integer .
