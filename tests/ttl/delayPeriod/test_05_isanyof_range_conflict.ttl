@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix ex:   <http://example.org/> .
@prefix dct:  <http://purl.org/dc/terms/> .

# =============================================================================
# TEST 05: isAnyOf with Range Conflict
# =============================================================================
# Description: delayPeriod must be one of {7D, 14D, 30D} AND greater than 60 days
# Scenario: "Standard embargo periods but minimum 60 days"
# Expected: CONFLICT
# Reason: All embargo options (7, 14, 30 days) are less than 60 days
# Analysis:
#   α(isAnyOf {604800, 1209600, 2592000}) = {604800, 1209600, 2592000}
#   α(gt 5184000) = (5184000, +∞)
#   Meet: {604800, 1209600, 2592000} ∩ (5184000, +∞) = ∅
# =============================================================================

ex:policy_delay_period_05
    a odrl:Set ;
    dct:description "isAnyOf with range conflict: embargo options 7/14/30 days but must be >60 days"@en ;
    odrl:uid ex:policy_delay_period_05 ;
    odrl:permission [
        a odrl:Permission ;
        odrl:action odrl:distribute ;
        odrl:target ex:asset_05 ;
        odrl:constraint ex:constraint_05_composite
    ] .

ex:constraint_05_composite
    a odrl:Constraint ;
    odrl:and (ex:constraint_05a ex:constraint_05b) .

ex:constraint_05a
    a odrl:Constraint ;
    odrl:leftOperand odrl:delayPeriod ;
    odrl:operator odrl:isAnyOf ;
    odrl:rightOperand ("P7D"^^xsd:duration "P14D"^^xsd:duration "P30D"^^xsd:duration) .

ex:constraint_05b
    a odrl:Constraint ;
    odrl:leftOperand odrl:delayPeriod ;
    odrl:operator odrl:gt ;
    odrl:rightOperand "P60D"^^xsd:duration .
