  {
    "@id": "http://w3id.org/odrl/bcp47/en-US",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/language": [
      {
        "@id": "https://www.omg.org/spec/LCC/Languages/ISO639-1-LanguageCodes/English"
      }
    ],
    "http://purl.org/dc/terms/source": [
      {
        "@id": "https://www.rfc-editor.org/rfc/rfc5646#section-2.2.4"
      }
    ],
    "http://purl.org/dc/terms/spatial": [
      {
        "@id": "https://www.omg.org/spec/LCC/Countries/ISO3166-1-CountryCodes/UnitedStates"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "English (United States) is a regional variant of English. Per BCP47 (RFC 5646, Section 2.2.4), regional subtags (ISO 3166-1) specialize the primary language by geographic usage. The hierarchy 'en-US skos:broader en' represents that US variant is a more specific form of the base language."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "http://w3id.org/odrl/bcp47/en"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "http://w3id.org/odrl/bcp47/scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#language",
        "@value": "en-US"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#note": [
      {
        "@language": "en",
        "@value": "BCP47 tag decomposed into components: language 'en' (ISO 639-1) → lcc-639-1:English, region 'US' (ISO 3166-1) → lcc-3166-1:UnitedStates. This component pattern applies to all [language]-[region] tags in this ontology."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "English (United States)"
      }
    ]
  },
