    <dct:conformsTo rdf:resource="https://www.omg.org/spec/LCC/Languages/ISO15924-CodeSet/Hant"/>
    <dct:source rdf:resource="https://www.rfc-editor.org/rfc/rfc5646#section-2.1"/>
  </rdf:Description>
