@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ex: <http://example.org/> .

# AND with contradictory children - count < 5 AND count > 10 is impossible
ex:policy a odrl:Policy ;
    odrl:permission [
        odrl:action odrl:use ;
        odrl:constraint ex:and_constraint
    ] .

ex:and_constraint a odrl:LogicalConstraint ;
    odrl:and ex:c1, ex:c2 .

ex:c1 a odrl:Constraint ;
    odrl:leftOperand odrl:count ;
    odrl:operator odrl:lt ;
    odrl:rightOperand "5"^^xsd:integer .

ex:c2 a odrl:Constraint ;
    odrl:leftOperand odrl:count ;
    odrl:operator odrl:gt ;
    odrl:rightOperand "10"^^xsd:integer .
