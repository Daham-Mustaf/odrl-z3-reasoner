@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix ex:   <http://example.org/> .

# EXPECTED: CONFLICT
# Reason: both branches can be true

ex:policy a odrl:Set ;
  odrl:permission [
    odrl:action odrl:use ;
    odrl:constraint [
      odrl:xone (
        [ odrl:leftOperand odrl:count ; odrl:operator odrl:lt ; odrl:rightOperand "10" ]
        [ odrl:leftOperand odrl:count ; odrl:operator odrl:lt ; odrl:rightOperand "20" ]
      )
    ]
  ] .
