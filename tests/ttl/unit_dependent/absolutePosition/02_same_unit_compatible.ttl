@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt: <http://qudt.org/vocab/unit/> .
@prefix ex: <http://example.org/> .

# TEST: Same unit (SEC), valid range → POSSIBLY-COMPATIBLE
# c1: absolutePosition gteq 30 SEC (start after 30s)
# c2: absolutePosition lteq 120 SEC (end before 2min)
# Expected: POSSIBLY-COMPATIBLE (e.g., 60 seconds)

ex:policy a odrl:Set ;
    odrl:uid ex:policy ;
    odrl:permission ex:perm1 .

ex:perm1 a odrl:Permission ;
    odrl:action odrl:play ;
    odrl:constraint ex:c1, ex:c2 .

ex:c1 a odrl:Constraint ;
    odrl:uid ex:c1 ;
    odrl:leftOperand odrl:absolutePosition ;
    odrl:operator odrl:gteq ;
    odrl:rightOperand "30"^^xsd:decimal ;
    odrl:unit qudt:SEC .

ex:c2 a odrl:Constraint ;
    odrl:uid ex:c2 ;
    odrl:leftOperand odrl:absolutePosition ;
    odrl:operator odrl:lteq ;
    odrl:rightOperand "120"^^xsd:decimal ;
    odrl:unit qudt:SEC .